# ────────────────────────────────────────────
#  alphaTrade Frontend — Environment Template
#  Copy this file to .env and fill in values
# ────────────────────────────────────────────

# API Gateway base URL (backend)
# Default: http://localhost:8080 (local Docker stack)
VITE_API_BASE_URL=http://localhost:8080

# WebSocket URL for live price feed
# Default: ws://localhost:8080
VITE_WS_URL=ws://localhost:8080

# ── Demo credentials (optional — prefills login form) ──
# Remove or leave empty in production
VITE_DEMO_EMAIL=
VITE_DEMO_PASSWORD=
