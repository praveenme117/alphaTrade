# ──────────────────────────────────────────────────────────────
# Trading Platform — Environment Variables
# Copy this file to .env and fill in values for local development
# NEVER commit .env to git
# ──────────────────────────────────────────────────────────────

# JWT Secret (min 32 chars, base64-encoded)
# Generate: openssl rand -base64 64
JWT_SECRET=dGhpcy1pcy1hLWRldi1vbmx5LXNlY3JldC1rZXktcGxlYXNlLWNoYW5nZS1pbi1wcm9kdWN0aW9u

# Database (Docker Compose defaults — change for external DBs)
DB_USER=trading
DB_PASSWORD=trading_secret

# Kafka
KAFKA_SERVERS=localhost:9092

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Payment Gateways (mock in dev — not needed unless testing real gateways)
# STRIPE_API_KEY=sk_test_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
# RAZORPAY_KEY_ID=rzp_test_xxx
# RAZORPAY_KEY_SECRET=xxx

# Notifications (mock email logger used in dev — no real API key needed)
# SENDGRID_API_KEY=SG.xxx

# Spring profiles
SPRING_PROFILES_ACTIVE=dev
